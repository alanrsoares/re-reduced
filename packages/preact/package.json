{
  "name": "@re-reduced/preact",
  "version": "0.2.3",
  "description": "Preact bindings for re-reduced (native signal rendering).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alanrsoares/re-reduced.git",
    "directory": "packages/preact"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "bun test",
    "prepack": "node ../../scripts/swap-publish-fields.mjs prepack",
    "postpack": "node ../../scripts/swap-publish-fields.mjs postpack"
  },
  "license": "MIT",
  "peerDependencies": {
    "@preact/signals": ">=1.3.0",
    "preact": ">=10.11.0",
    "typescript": ">=6"
  },
  "dependencies": {
    "@re-reduced/core": "^0.3.2"
  },
  "devDependencies": {
    "@preact/signals": "^1.3.0",
    "@testing-library/preact": "^3.2.4",
    "preact": "^10.24.0",
    "ts-expect": "^1.3.0"
  }
}
