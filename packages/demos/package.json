{
  "name": "@re-reduced/demos",
  "version": "0.0.0",
  "private": true,
  "description": "Shared demo container + views (single source of truth for examples and docs). Not published.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/todos.ts",
      "default": "./src/todos.ts"
    },
    "./react": {
      "types": "./src/react.tsx",
      "default": "./src/react.tsx"
    },
    "./life-store": {
      "types": "./src/life-store.ts",
      "default": "./src/life-store.ts"
    },
    "./life": {
      "types": "./src/life.tsx",
      "default": "./src/life.tsx"
    },
    "./life.css": "./src/life.css"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "typescript": ">=6"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@re-reduced/adapter-kit": "workspace:*",
    "@re-reduced/core": "workspace:*",
    "@re-reduced/react": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  }
}
