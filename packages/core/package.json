{
  "name": "@re-reduced/core",
  "version": "0.3.1",
  "description": "Signal-backed functional state-machine + effect container.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alanrsoares/re-reduced.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "bun test",
    "prepack": "node ../../scripts/swap-publish-fields.mjs prepack",
    "postpack": "node ../../scripts/swap-publish-fields.mjs postpack"
  },
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=6"
  },
  "dependencies": {
    "@re-reduced/signals": "^0.2.0"
  },
  "devDependencies": {
    "ts-expect": "^1.3.0"
  }
}
