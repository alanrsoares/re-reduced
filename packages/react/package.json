{
  "name": "@re-reduced/react",
  "version": "0.3.1",
  "description": "React bindings for re-reduced (useContainer/useSelect/useWatch + context).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alanrsoares/re-reduced.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "bun test",
    "prepack": "node ../../scripts/swap-publish-fields.mjs prepack",
    "postpack": "node ../../scripts/swap-publish-fields.mjs postpack"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "typescript": ">=6"
  },
  "dependencies": {
    "@re-reduced/core": "^0.3.2"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.10.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-expect": "^1.3.0"
  }
}
