{
	"name": "re-reduced",
	"version": "2.5.4",
	"description": "Frozen v1 (Redux/redux-saga helper). Superseded by the @re-reduced/* v2 line.",
	"main": "dist/index.js",
	"umd:main": "dist/re-reduced.umd.production.js",
	"module": "dist/index.mjs",
	"typings": "dist/index.d.ts",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"es"
	],
	"scripts": {
		"build": "esbuild src/index.ts --bundle --format=cjs --outfile=dist/index.js --external:react --external:react-redux --external:redux --external:redux-saga --external:ramda --external:fsevents",
		"typecheck": "tsc -p tsconfig.test.json",
		"test": "bun test"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alanrsoares/re-reduced.git"
	},
	"keywords": [
		"redux",
		"higher-order-reducer",
		"react",
		"immutable",
		"functional programming"
	],
	"author": "Alan Soares <alanrsoars@gmail.com>",
	"license": "MIT",
	"peerDependencies": {
		"react-redux": ">=7.1.0",
		"redux": ">=4",
		"redux-saga": ">=1"
	},
	"dependencies": {
		"ramda": "^0.27.1"
	},
	"devDependencies": {
		"@types/jest": "^26.0.15",
		"@types/ramda": "^0.27.32",
		"@types/react": "^16.9.55",
		"@types/react-redux": "^7.1.11",
		"@types/styled-components": "^5.1.4",
		"esbuild": "^0.25.0",
		"react": "^17.0.1",
		"react-dom": "^17.0.1",
		"react-redux": "^7.2.2",
		"redux": "^4.0.5",
		"redux-saga": "^1.1.3",
		"redux-saga-test-plan": "^4.0.1",
		"reselect": "^4.0.0",
		"styled-components": "^5.2.1",
		"ts-expect": "^1.3.0"
	}
}
