{
	"name": "re-reduced",
	"version": "2.5.4",
	"main": "dist/index.js",
	"umd:main": "dist/re-reduced.umd.production.js",
	"module": "dist/index.mjs",
	"typings": "dist/index.d.ts",
	"files": [
		"dist",
		"es"
	],
	"scripts": {
		"start": "tsup --watch",
		"build": "esbuild src/index.ts --bundle --format=esm,cjs --outfile=dist/index --external:react --external:react-redux --external:redux --external:redux-saga --external:ramda --external:fsevents",
		"test": "bun test",
		"test:coverage": "bun test",
		"prepare": "bun run build",
		"preversion": "scripts/build_es.sh",
		"prepublishOnly": "bun test",
		"postversion": "git push && git push --tags",
		"docs": "typedoc",
		"docs:build": "typedoc",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc -p tsconfig.test.json",
		"check": "bun run lint && bun run typecheck && bun test",
		"dev": "tsup --watch"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alanrsoares/re-reduced.git"
	},
	"keywords": [
		"redux",
		"higher-order-reducer",
		"react",
		"immutable",
		"functional programming"
	],
	"author": "Alan Soares <alanrsoars@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/alanrsoares/re-reduced/issues"
	},
	"homepage": "https://github.com/alanrsoares/re-reduced#readme",
	"peerDependencies": {
		"react-redux": ">=7.1.0",
		"redux": ">=4",
		"redux-saga": ">=1"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"biome check --write"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/bun": "^1.3.14",
		"@types/jest": "^26.0.15",
		"@types/ramda": "^0.27.32",
		"@types/react": "^16.9.55",
		"@types/react-redux": "^7.1.11",
		"@types/styled-components": "^5.1.4",
		"husky": "^4.3.0",
		"lint-staged": "^10.5.1",
		"react": "^17.0.1",
		"react-dom": "^17.0.1",
		"react-redux": "^7.2.2",
		"redux": "^4.0.5",
		"redux-saga": "^1.1.3",
		"redux-saga-test-plan": "^4.0.1",
		"reselect": "^4.0.0",
		"styled-components": "^5.2.1",
		"ts-expect": "^1.3.0",
		"tsup": "^8.5.1",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"ramda": "^0.27.1"
	},
	"types": "dist/index.d.ts"
}
