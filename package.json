{
  "name": "re-reduced-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "re-reduced v2 — signal-backed functional state container. Monorepo root.",
  "workspaces": [
    "packages/*",
    "examples/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "build": "bun run --filter './packages/*' build",
    "check": "bun run lint && bun run typecheck && bun test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alanrsoares/re-reduced.git"
  },
  "author": "Alan Soares <alanrsoars@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
